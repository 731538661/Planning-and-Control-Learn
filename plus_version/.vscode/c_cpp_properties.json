{
  "version": 4,
  "configurations": [
    {
      "name": "ROS2 Workspace",
      "compilerPath": "cl.exe",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c11",
      "cppStandard": "c++14",
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/build/**",
        "${workspaceFolder}/install/**",
        "${env:AMENT_PREFIX_PATH}/include/**"
      ],
      "defines": [
        "ROS2=1"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/build",
          "${workspaceFolder}/install"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
